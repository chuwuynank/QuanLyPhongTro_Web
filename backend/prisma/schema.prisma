generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enum
enum RoomStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
}

enum UserRole {
  TENANT
  LANDLORD
  ADMIN
}


model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  fullName      String
  phone         String?
  role          UserRole  @default(TENANT)
  rooms         Room[]    // Phòng do chủ trọ đăng
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model RoomType {
  id          String @id @default(uuid())
  name        String @unique  // ví dụ: Phòng trọ, Studio, Chung cư mini, Nhà nguyên căn
  rooms       Room[]
}
